    PUSHBUTTON      "Load",IDC_BTN_LOAD_OSW,260,91,35,14

    LTEXT           "Mode:", -1,310,94,22,8
    COMBOBOX        IDC_COMBO_OSW_CONN_MODE,335,92,85,60,CBS_DROPDOWNLIST | WS_TABSTOP

    LTEXT           "Address:", -1,15,114,30,8
    COMBOBOX        IDC_COMBO_OSW_ADDR,48,112,200,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,255,114,18,8
    EDITTEXT        IDC_EDIT_OSW_PORT,275,112,35,13,ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "Enumerate",IDC_BTN_ENUMERATE_OSW,320,111,55,14

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_OSW,15,132,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_OSW,80,132,60,16
    LTEXT           "Status:",  -1,155,135,25,8
    LTEXT           "Not Connected",IDC_STATIC_OSW_STATUS,183,135,300,8

    // ===== OSW2 Connection Group =====
    GROUPBOX        "OSW2 Connection (mOSW-C1)",IDC_GROUP_OSW2,5,157,630,75
    LTEXT           "OSW DLL:",  -1,15,171,35,8
    EDITTEXT        IDC_EDIT_OSW2_DLL,55,169,200,13,ES_AUTOHSCROLL
    PUSHBUTTON      "Load",IDC_BTN_LOAD_OSW2,260,168,35,14

    LTEXT           "Mode:", -1,310,171,22,8
    COMBOBOX        IDC_COMBO_OSW2_CONN_MODE,335,169,85,60,CBS_DROPDOWNLIST | WS_TABSTOP

    LTEXT           "Address:", -1,15,191,30,8
    COMBOBOX        IDC_COMBO_OSW2_ADDR,48,189,200,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,255,191,18,8
    EDITTEXT        IDC_EDIT_OSW2_PORT,275,189,35,13,ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "Enumerate",IDC_BTN_ENUMERATE_OSW2,320,188,55,14

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_OSW2,15,209,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_OSW2,80,209,60,16
    LTEXT           "Status:",  -1,155,212,25,8
    LTEXT           "Not Connected",IDC_STATIC_OSW2_STATUS,183,212,300,8

    // ===== Test Configuration Group =====
    GROUPBOX        "Test Configuration",IDC_GROUP_CONFIG,5,235,420,80
    LTEXT           "Wavelength:", -1,15,252,44,8
    CONTROL         "1310 nm",IDC_CHECK_1310,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,65,251,45,10
    CONTROL         "1550 nm",IDC_CHECK_1550,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,118,251,45,10
    LTEXT           "Channels:", -1,180,252,36,8

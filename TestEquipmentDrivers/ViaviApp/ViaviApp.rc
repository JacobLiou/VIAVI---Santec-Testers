    LTEXT           "OSW2 Dev#:", -1,372,252,42,8
    EDITTEXT        IDC_EDIT_OSW2_DEVICE_NUM,417,250,25,13,ES_AUTOHSCROLL | ES_NUMBER

    CONTROL         "Override Reference",IDC_CHECK_OVERRIDE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,275,80,10
    LTEXT           "IL (dB):", -1,100,276,28,8
    EDITTEXT        IDC_EDIT_IL_VALUE,132,274,40,13,ES_AUTOHSCROLL
    LTEXT           "Length (m):", -1,180,276,40,8
    EDITTEXT        IDC_EDIT_LENGTH_VALUE,225,274,40,13,ES_AUTOHSCROLL

    // ===== Operation Group =====
    GROUPBOX        "Operations",IDC_GROUP_OPERATION,430,235,205,80
    PUSHBUTTON      "Zeroing (Reference)",IDC_BTN_ZEROING,440,253,90,22
    PUSHBUTTON      "Measure",IDC_BTN_MEASURE,535,253,90,22
    PUSHBUTTON      "Continuous Test",IDC_BTN_CONTINUOUS,440,283,90,22
    PUSHBUTTON      "STOP",IDC_BTN_STOP,535,283,90,22

    // ===== Results Group =====
    GROUPBOX        "Measurement Results",IDC_GROUP_RESULTS,5,318,630,180
    CONTROL         "",IDC_LIST_RESULTS,"SysListView32",LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,10,331,620,162

    // ===== Log Group =====
    GROUPBOX        "Log",IDC_GROUP_LOG,5,501,630,170
    EDITTEXT        IDC_EDIT_LOG,10,514,620,135,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "afxres.h"
#undef APSTUDIO_READONLY_SYMBOLS

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE 9, 1

IDD_VIAVIAPP_DIALOG DIALOGEX 0, 0, 640, 600
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
CAPTION "Viavi - PCT/OSW Debug Tool"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ===== PCT Connection Group (TCP only) =====
    GROUPBOX        "PCT Connection (mORL-A1)",IDC_GROUP_PCT,5,3,630,45
    LTEXT           "PCT DLL:",  -1,15,17,35,8
    EDITTEXT        IDC_EDIT_PCT_DLL,55,15,140,13,ES_AUTOHSCROLL
    PUSHBUTTON      "Load",IDC_BTN_LOAD_PCT,199,14,35,14
    LTEXT           "Address:", -1,245,17,30,8
    COMBOBOX        IDC_COMBO_PCT_ADDR,278,15,143,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,428,17,18,8
    EDITTEXT        IDC_EDIT_PCT_PORT,448,15,35,13,ES_AUTOHSCROLL | ES_NUMBER

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_PCT,15,31,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_PCT,80,31,60,16
    LTEXT           "Status:",  -1,155,34,25,8
    LTEXT           "Not Connected",IDC_STATIC_PCT_STATUS,183,34,300,8

    // ===== OSW1 Connection Group (TCP only) =====
    GROUPBOX        "OSW1 Connection (mOSW-C1)",IDC_GROUP_OSW,5,50,630,45

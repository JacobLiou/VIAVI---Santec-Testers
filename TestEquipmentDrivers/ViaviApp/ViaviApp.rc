#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "afxres.h"
#undef APSTUDIO_READONLY_SYMBOLS

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE 9, 1

IDD_VIAVIAPP_DIALOG DIALOGEX 0, 0, 640, 700
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX
CAPTION "Viavi - PCT/OSW Debug Tool"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    // ===== PCT Connection Group =====
    GROUPBOX        "PCT Connection (mORL-A1)",IDC_GROUP_PCT,5,3,630,75
    LTEXT           "PCT DLL:",  -1,15,17,35,8
    EDITTEXT        IDC_EDIT_PCT_DLL,55,15,200,13,ES_AUTOHSCROLL
    PUSHBUTTON      "Load",IDC_BTN_LOAD_PCT,260,14,35,14

    LTEXT           "Mode:", -1,310,17,22,8
    COMBOBOX        IDC_COMBO_PCT_CONN_MODE,335,15,85,60,CBS_DROPDOWNLIST | WS_TABSTOP

    LTEXT           "Address:", -1,15,37,30,8
    COMBOBOX        IDC_COMBO_PCT_ADDR,48,35,200,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,255,37,18,8
    EDITTEXT        IDC_EDIT_PCT_PORT,275,35,35,13,ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "Enumerate",IDC_BTN_ENUMERATE_PCT,320,34,55,14

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_PCT,15,55,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_PCT,80,55,60,16
    LTEXT           "Status:",  -1,155,58,25,8
    LTEXT           "Not Connected",IDC_STATIC_PCT_STATUS,183,58,300,8

    // ===== OSW1 Connection Group =====
    GROUPBOX        "OSW1 Connection (mOSW-C1)",IDC_GROUP_OSW,5,80,630,75

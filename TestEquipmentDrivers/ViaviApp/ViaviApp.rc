    EDITTEXT        IDC_EDIT_OSW_DLL,55,62,140,13,ES_AUTOHSCROLL
    PUSHBUTTON      "Load",IDC_BTN_LOAD_OSW,199,61,35,14
    LTEXT           "Address:", -1,245,64,30,8
    COMBOBOX        IDC_COMBO_OSW_ADDR,278,62,143,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,428,64,18,8
    EDITTEXT        IDC_EDIT_OSW_PORT,448,62,35,13,ES_AUTOHSCROLL | ES_NUMBER

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_OSW,15,78,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_OSW,80,78,60,16
    LTEXT           "Status:",  -1,155,81,25,8
    LTEXT           "Not Connected",IDC_STATIC_OSW_STATUS,183,81,300,8

    // ===== OSW2 Connection Group (TCP only) =====
    GROUPBOX        "OSW2 Connection (mOSW-C1)",IDC_GROUP_OSW2,5,97,630,45
    LTEXT           "OSW DLL:",  -1,15,111,35,8
    EDITTEXT        IDC_EDIT_OSW2_DLL,55,109,140,13,ES_AUTOHSCROLL
    PUSHBUTTON      "Load",IDC_BTN_LOAD_OSW2,199,108,35,14
    LTEXT           "Address:", -1,245,111,30,8
    COMBOBOX        IDC_COMBO_OSW2_ADDR,278,109,143,120,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Port:", -1,428,111,18,8
    EDITTEXT        IDC_EDIT_OSW2_PORT,448,109,35,13,ES_AUTOHSCROLL | ES_NUMBER

    PUSHBUTTON      "Connect",IDC_BTN_CONNECT_OSW2,15,125,60,16
    PUSHBUTTON      "Disconnect",IDC_BTN_DISCONNECT_OSW2,80,125,60,16
    LTEXT           "Status:",  -1,155,128,25,8
    LTEXT           "Not Connected",IDC_STATIC_OSW2_STATUS,183,128,300,8

    // ===== Test Configuration Group =====
    GROUPBOX        "Test Configuration",IDC_GROUP_CONFIG,5,144,420,80
    LTEXT           "Wavelength:", -1,15,161,44,8
    CONTROL         "1310 nm",IDC_CHECK_1310,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,65,160,45,10
    CONTROL         "1550 nm",IDC_CHECK_1550,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,118,160,45,10
    LTEXT           "Channels:", -1,180,161,36,8
    EDITTEXT        IDC_EDIT_CH_FROM,220,159,25,13,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "~", -1,248,161,8,8,SS_CENTER
    EDITTEXT        IDC_EDIT_CH_TO,258,159,25,13,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "OSW1:", -1,295,161,22,8
    EDITTEXT        IDC_EDIT_OSW_DEVICE_NUM,319,159,25,13,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "OSW2:", -1,350,161,22,8
    EDITTEXT        IDC_EDIT_OSW2_DEVICE_NUM,374,159,25,13,ES_AUTOHSCROLL | ES_NUMBER

    CONTROL         "Override Reference",IDC_CHECK_OVERRIDE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,184,80,10
    LTEXT           "IL (dB):", -1,100,185,28,8
    EDITTEXT        IDC_EDIT_IL_VALUE,132,183,40,13,ES_AUTOHSCROLL
    LTEXT           "Length (m):", -1,180,185,40,8
    EDITTEXT        IDC_EDIT_LENGTH_VALUE,225,183,40,13,ES_AUTOHSCROLL

    // ===== Operation Group =====
    GROUPBOX        "Operations",IDC_GROUP_OPERATION,430,144,205,80
    PUSHBUTTON      "Zeroing (Reference)",IDC_BTN_ZEROING,440,162,90,22
    PUSHBUTTON      "Measure",IDC_BTN_MEASURE,535,162,90,22
    PUSHBUTTON      "STOP",IDC_BTN_STOP,535,192,90,22

    // ===== Results Group =====
    GROUPBOX        "Measurement Results",IDC_GROUP_RESULTS,5,227,630,180
    CONTROL         "",IDC_LIST_RESULTS,"SysListView32",LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,10,240,620,162

    // ===== Log Group =====
    GROUPBOX        "Log",IDC_GROUP_LOG,5,410,630,170
    EDITTEXT        IDC_EDIT_LOG,10,423,620,135,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL
    PUSHBUTTON      "Clear Log",IDC_BTN_CLEAR_LOG,10,563,55,16

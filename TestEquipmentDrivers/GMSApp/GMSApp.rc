    LTEXT           "Length (m):", -1,180,120,40,8
    EDITTEXT        IDC_EDIT_LENGTH_VALUE,225,118,40,13,ES_AUTOHSCROLL

    // ===== Operation Group =====
    GROUPBOX        "Operations",IDC_GROUP_OPERATION,410,79,205,80

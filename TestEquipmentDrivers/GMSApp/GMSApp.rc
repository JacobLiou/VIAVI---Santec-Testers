    EDITTEXT        IDC_EDIT_CH_TO,258,94,25,13,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Switch #:", -1,295,96,35,8
    COMBOBOX        IDC_COMBO_SWITCH_NUM,333,94,60,80,CBS_DROPDOWNLIST | WS_TABSTOP

    CONTROL         "Override Reference",IDC_CHECK_OVERRIDE,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,119,80,10
    LTEXT           "IL (dB):", -1,100,120,28,8

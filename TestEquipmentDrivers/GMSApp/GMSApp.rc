    // ===== Results Group =====
    GROUPBOX        "Measurement Results",IDC_GROUP_RESULTS,5,162,610,200
    CONTROL         "",IDC_LIST_RESULTS,"SysListView32",LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,10,175,600,182

    // ===== Log Group =====
    GROUPBOX        "Log",IDC_GROUP_LOG,5,365,610,151

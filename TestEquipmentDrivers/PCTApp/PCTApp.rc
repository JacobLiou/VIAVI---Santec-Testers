    CONTROL         "J2",IDC_RADIO_DUAL_J2,"Button",BS_AUTORADIOBUTTON | WS_TABSTOP,270,99,24,10
    CONTROL         "Bidirectional",IDC_CHECK_BIDIR,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,300,99,55,10
    LTEXT           "Launch Ch:",IDC_STATIC_SW1_LABEL,12,120,40,8
    EDITTEXT        IDC_EDIT_SW1_FROM,54,118,25,13,ES_AUTOHSCROLL
    LTEXT           "to",IDC_STATIC_SW1_TO,82,120,8,8
    EDITTEXT        IDC_EDIT_SW1_TO,92,118,25,13,ES_AUTOHSCROLL
    LTEXT           "Receive Ch:",IDC_STATIC_SW2_LABEL,124,120,42,8
